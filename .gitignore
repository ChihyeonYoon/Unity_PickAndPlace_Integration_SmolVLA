# This .gitignore file is based on Unity's recommended .gitignore for best practices.
# It ensures that unnecessary generated files, temporary files, and platform-specific
# library builds are excluded from version control, keeping the repository clean
# and focused on essential project assets and source code.

# Folders generated by Unity
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Rr]esults/
/[Dd]ata/
/Logs/

# Autogenerated C# projects (e.g. for Visual Studio, Rider)
/*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity metadata files
.DS_Store
.vscode/

# Visual Studio specific files (if applicable)
.vs/
*.bak

# Rider specific files
.idea/

# Dotnet tool restore file
.config/dotnet-tools.json

# Cache files for external packages
/[Pp]ackages/[Cc]ache/

# Mac specific files
.DS_Store
.Trashes
Thumbs.db

# Any other editor/tool temporary files
*~
*.log
*.log.data
*.backup
*.meta.orig

# Generated file for ROS messages and services (if applicable, typically under Assets/RosMessages)
/Assets/RosMessages/

# Custom ignore patterns for this project (if any)
# For example, to ignore specific generated files in the Docker directory:
/docker/.docker_cache/
